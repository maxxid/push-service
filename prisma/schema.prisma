generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  COMPANY_OWNER
  COMPANY_EDITOR
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

enum CampaignPriority {
  NORMAL
  URGENTE
}

enum ActionType {
  LANDING_INTERNA
  WHATSAPP
  PDF
  MAPS
  URL_EXTERNA
  LLAMAR
  FORMULARIO
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role          @default(COMPANY_EDITOR)
  companyId     String?
  company       Company?      @relation(fields: [companyId], references: [id])
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Company {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  subdomain   String    @unique
  logo        String?
  primaryColor String   @default("#1a56db")
  secondaryColor String @default("#ffffff")
  users       User[]
  subscribers Subscriber[]
  segments    Segment[]
  campaigns   Campaign[]
  landingPages LandingPage[]
  modules     Json      @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Subscriber {
  id            String        @id @default(cuid())
  onesignalId   String        @unique
  deviceInfo    Json?
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  segments      SubscriberSegment[]
  subscribedAt  DateTime      @default(now())
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Segment {
  id          String        @id @default(cuid())
  name        String
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscribers SubscriberSegment[]
  campaigns   Campaign[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([name, companyId])
}

model SubscriberSegment {
  subscriberId String
  segmentId    String
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  segment      Segment    @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@id([subscriberId, segmentId])
}

model Campaign {
  id             String          @id @default(cuid())
  title          String
  pushMessage    String
  imageUrl       String?
  status         CampaignStatus  @default(DRAFT)
  priority       CampaignPriority @default(NORMAL)
  actionType     ActionType      @default(LANDING_INTERNA)
  actionValue    String?
  scheduledAt    DateTime?
  sentAt         DateTime?
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  segmentId      String?
  segment        Segment?        @relation(fields: [segmentId], references: [id])
  landingPageId  String?
  landingPage    LandingPage?    @relation(fields: [landingPageId], references: [id])
  deliveries     Int             @default(0)
  clicks         Int             @default(0)
  createdBy      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model LandingPage {
  id          String     @id @default(cuid())
  title       String
  slug        String
  content     Json       @default("[]")
  published   Boolean    @default(false)
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaigns   Campaign[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([slug, companyId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  details   Json?
  userId    String?
  companyId String?
  createdAt DateTime @default(now())
}
